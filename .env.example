# =============================================================================
# AURA CAMERA APP - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Aura Camera"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_PYTHON_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/aura_camera

# For Prisma direct connection (optional)
DIRECT_URL=postgresql://username:password@localhost:5432/aura_camera

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-nextauth-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (Optional)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# CLOUDINARY - Image Storage
# Get from: https://cloudinary.com/console
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# STRIPE - Payment Processing
# Get from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in your Stripe Dashboard)
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# -----------------------------------------------------------------------------
# OPENAI - Reading Generation
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# PYTHON ML API CONFIGURATION
# -----------------------------------------------------------------------------
PYTHON_API_PORT=8000
PYTHON_API_HOST=0.0.0.0
PYTHON_API_DEBUG=true

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS (Optional)
# -----------------------------------------------------------------------------
# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Optional - for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@auracamera.app

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_SUBSCRIPTIONS=true
ENABLE_SOCIAL_SHARING=true
ENABLE_ANALYTICS=false
ENABLE_EMAIL_NOTIFICATIONS=false

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=true
